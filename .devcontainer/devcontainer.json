{
  "name": "Terraform AWS AFT Management",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "aws-ia.amazon-q-developer",
        "eamodio.gitlens",
        "GitHub.copilot"
      ],
      "settings": {
        "[hcl]": {
          "editor.formatOnSave": true
        },
        "[terraform]": {
          "editor.formatOnSave": true
        }
      }
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "terraform version && aws --version && gh --version"
}